# ============================================
# STATISTICAL BUSINESS ANALYSIS (CHURN DATA)
# ============================================

import pandas as pd
import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt
from scipy import stats
import statsmodels.api as sm

# --------------------------------------------
# 1️⃣ LOAD DATA
# --------------------------------------------

df = pd.read_csv("/content/customer_churn.csv")

df.columns = df.columns.str.strip()

print("Dataset Shape:", df.shape)
print("Columns:", df.columns)

# Convert TotalCharges to numeric (important fix)
df["TotalCharges"] = pd.to_numeric(df["TotalCharges"], errors="coerce")

df = df.dropna()

# --------------------------------------------
# 2️⃣ SET BUSINESS METRIC
# --------------------------------------------

sales_col = "TotalCharges"

# --------------------------------------------
# 3️⃣ DESCRIPTIVE STATISTICS
# --------------------------------------------

mean_val = df[sales_col].mean()
median_val = df[sales_col].median()
mode_val = df[sales_col].mode()[0]
std_val = df[sales_col].std()

print("\n===== DESCRIPTIVE STATISTICS =====")
print(f"Mean: {mean_val:,.2f}")
print(f"Median: {median_val:,.2f}")
print(f"Mode: {mode_val:,.2f}")
print(f"Std Dev: {std_val:,.2f}")

# --------------------------------------------
# 4️⃣ DISTRIBUTION ANALYSIS
# --------------------------------------------

plt.figure(figsize=(8,5))
sns.histplot(df[sales_col], kde=True)
plt.title("Total Charges Distribution")
plt.show()

shapiro = stats.shapiro(df[sales_col])
print("Shapiro Test p-value:", shapiro.pvalue)

# --------------------------------------------
# 5️⃣ CORRELATION ANALYSIS
# --------------------------------------------

numeric_cols = df.select_dtypes(include=np.number).columns
corr_matrix = df[numeric_cols].corr()

print("\nCorrelation Matrix:\n", corr_matrix)

plt.figure(figsize=(8,6))
sns.heatmap(corr_matrix, annot=True, cmap="coolwarm")
plt.title("Correlation Heatmap")
plt.show()

# --------------------------------------------
# 6️⃣ HYPOTHESIS TESTS (3 REQUIRED)
# --------------------------------------------

print("\n===== HYPOTHESIS TESTING =====")

# H1: MonthlyCharges affects TotalCharges
corr, p1 = stats.pearsonr(df["MonthlyCharges"], df["TotalCharges"])
print("H1: MonthlyCharges vs TotalCharges")
print("p-value:", p1)

# H2: SeniorCitizen vs Non-Senior (T-test)
group1 = df[df["SeniorCitizen"] == 1]["TotalCharges"]
group2 = df[df["SeniorCitizen"] == 0]["TotalCharges"]

t_stat, p2 = stats.ttest_ind(group1, group2)
print("\nH2: Senior vs Non-Senior")
print("p-value:", p2)

# H3: Contract Type Comparison (ANOVA)
groups = [df[df["Contract"] == c]["TotalCharges"] for c in df["Contract"].unique()]
anova = stats.f_oneway(*groups)
print("\nH3: Contract Type ANOVA")
print("p-value:", anova.pvalue)

# --------------------------------------------
# 7️⃣ CONFIDENCE INTERVAL (95%)
# --------------------------------------------

n = len(df[sales_col])
margin_error = stats.t.ppf(0.975, n-1) * (std_val/np.sqrt(n))

lower = mean_val - margin_error
upper = mean_val + margin_error

print("\n95% Confidence Interval:")
print(f"{lower:,.2f} to {upper:,.2f}")

# --------------------------------------------
# 8️⃣ REGRESSION ANALYSIS
# --------------------------------------------

X = df[["MonthlyCharges", "Tenure"]]
y = df["TotalCharges"]

X = sm.add_constant(X)

model = sm.OLS(y, X).fit()

print("\n===== REGRESSION RESULTS =====")
print(model.summary())

print("\nR-Squared:", model.rsquared)

# --------------------------------------------
# FINAL REPORT
# --------------------------------------------

print("\n" + "="*60)
print("STATISTICAL ANALYSIS REPORT")
print("="*60)
print(f"Average Revenue: ${mean_val:,.0f} ± ${margin_error:,.0f} (95% CI)")
print(f"Correlation (MonthlyCharges-TotalCharges): {corr:.2f}")
print(f"p-value: {p1:.4f}")
print("="*60)
